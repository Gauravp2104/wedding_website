# ─────────────────────────────────────────────────────────────
#  Gautam & Sandhya Wedding — Backend configuration
#  Copy this file to ".env" and adjust as needed.
#  Every RSVP is saved to data/rsvps.json. Photos go to data/uploads/.
# ─────────────────────────────────────────────────────────────

PORT=4000

# Point at a persistent volume in production so data survives restarts,
# e.g. DATA_DIR=/data  (RSVPs → /data/rsvps.json, photos → /data/uploads).
# DATA_DIR=/data

# ── Photo album admin ────────────────────────────────────────
# Shared password required to upload photos to the album.
ADMIN_PASSWORD=choose-a-private-password
