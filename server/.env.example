# ─────────────────────────────────────────────────────────────
#  Gautam & Sandhya Wedding — Backend configuration
#  Copy this file to ".env" and fill in the email settings.
#  RSVPs are saved to data/rsvps.json; every RSVP also emails the
#  recipients listed in RSVP_NOTIFY_TO.
# ─────────────────────────────────────────────────────────────

PORT=4000

# ── Email notifications (sent on every RSVP) ──────────────────
# Any SMTP provider works. For Gmail, create an App Password
# (Google Account → Security → 2-Step Verification → App passwords)
# and use it as SMTP_PASS.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-address@gmail.com
SMTP_PASS=your-app-password

# Comma- or space-separated list of people to notify on each RSVP.
RSVP_NOTIFY_TO=host1@example.com, host2@example.com

# Optional From: address (defaults to SMTP_USER).
RSVP_NOTIFY_FROM=your-address@gmail.com

# ── Google Sheets mirror ──────────────────────────────────────
# Optional locally (RSVPs always save to data/rsvps.json). When set, each
# RSVP is also appended to the Sheet. Required on Vercel (durable store).
# Create a service account, enable the Sheets API, share the Sheet with the
# service-account email (Editor). Paste the private key with literal \n.
GOOGLE_SHEET_ID=your-sheet-id
GOOGLE_SERVICE_ACCOUNT_EMAIL=svc@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_TAB=RSVPs

# ── Photo album admin ────────────────────────────────────────
# Shared password required to upload photos to the album.
# On Vercel, also connect a Blob store (auto-injects BLOB_READ_WRITE_TOKEN).
ADMIN_PASSWORD=choose-a-private-password
